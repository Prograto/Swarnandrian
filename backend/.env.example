# ─────────────────────────────────────────────────────────────
# Backend Environment Variables — Render Web Service
# Add ALL of these in: Render Dashboard > your service > Environment
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Swarnandrian

# MongoDB database name
MONGODB_DB_NAME=swarnandrian

# JWT Secret (use a strong random string in production)
JWT_SECRET_KEY=change-this-to-a-strong-random-secret

# Token expiry in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# URL of your deployed code-runner service on Render
# Example: https://swarnandrian-code-runner.onrender.com
CODE_RUNNER_URL=https://YOUR-CODE-RUNNER.onrender.com

# Must match CODE_RUNNER_SECRET in your code-runner service
CODE_RUNNER_SECRET=SwarnandrianCodeRunnerSecret

# Comma-separated list of allowed frontend origins (no trailing slash)
# Add your Vercel URL here once deployed
ALLOWED_ORIGINS_STR=https://YOUR-APP.vercel.app,https://YOUR-CUSTOM-DOMAIN.com

# Your Vercel frontend URL
FRONTEND_URL=https://YOUR-APP.vercel.app

# App mode
APP_NAME=Swarnandrian
APP_ENV=production

# AWS S3 (for media/file uploads) — leave blank to disable
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-south-1
AWS_S3_BUCKET=swarnandrian

# Limits
MAX_BULK_UPLOAD_USERS=2000
MAX_FILE_SIZE_MB=50
SANDBOX_TIMEOUT=10
