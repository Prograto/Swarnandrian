# ─── Swarnandrian Backend Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values

# MongoDB
MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_DB_NAME=swarnandrian

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Code Runner
CODE_RUNNER_URL=http://localhost:8001
CODE_RUNNER_SECRET=your-code-runner-secret

# CORS (comma-separated frontend URLs)
ALLOWED_ORIGINS_STR=http://localhost:3000,https://your-vercel-app.vercel.app
FRONTEND_URL=http://localhost:3000

# AWS S3 (for file/image uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=swarnandrian

# Redis
REDIS_URL=redis://localhost:6379/0

# Groq AI (for chatbot — get free key at console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# App
APP_ENV=development
