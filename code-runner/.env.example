# ─────────────────────────────────────────────────────────────
# Code Runner Environment Variables — Render Web Service
# Add ALL of these in: Render Dashboard > your service > Environment
# ─────────────────────────────────────────────────────────────

# Must match CODE_RUNNER_SECRET in your backend service
CODE_RUNNER_SECRET=SwarnandrianCodeRunnerSecret

# Comma-separated browser origins allowed to call this service directly.
# Keep localhost for development and add your deployed frontend origin(s) on Render/Vercel.
ALLOWED_ORIGINS_STR=http://localhost:3000,http://localhost:80

# Execution timeout per submission (seconds)
SANDBOX_TIMEOUT=10
