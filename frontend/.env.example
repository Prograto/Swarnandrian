# ─── Swarnandrian Frontend Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values

# API base URL — in production this is your backend URL
REACT_APP_API_URL=https://your-backend.onrender.com/api/v1

# For local dev, leave blank or set to /api/v1 (nginx proxy handles it)
# REACT_APP_API_URL=/api/v1
