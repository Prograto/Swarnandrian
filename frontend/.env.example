# ─────────────────────────────────────────────────────────────
# Frontend Environment Variables
# For LOCAL dev: copy this to .env.local and fill in values
# For VERCEL: add these in Vercel Dashboard > Settings > Environment Variables
# ─────────────────────────────────────────────────────────────

# Your Render backend URL — /api/v1 suffix (used by axios)
REACT_APP_API_URL=https://YOUR-BACKEND.onrender.com/api/v1

# Your Render backend base URL (used to derive WebSocket wss:// URL)
REACT_APP_BACKEND_URL=https://YOUR-BACKEND.onrender.com
